#!/bin/sh
# ==============================================================================
# Post-Removal Script
# Cleans up temporary caches, statistics files, and dynamic configurations.
# ==============================================================================
#!/bin/sh
echo "[*] Cleaning LuCI cache after removal..."
rm -f /usr/share/luci/menu.d/luci-app-telemt.json
rm -rf /tmp/luci-modulecache/
rm -f /tmp/luci-indexcache
/etc/init.d/rpcd reload 2>/dev/null || true
exit 0
